# Copy to .env.local for local development, or set these as build-time env vars in your deploy.

# Canonical public site URL used for metadata, sitemap.xml, and robots.txt.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Discord invite used across landing/community/footer CTAs.
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/6SRhbZw7ZG

# Mailbox used by the waitlist fallback when Formspree is not configured.
NEXT_PUBLIC_WAITLIST_EMAIL=yurlovandrew@gmail.com

# Formspree endpoint or bare form id for real waitlist capture.
# Accepted examples:
#   NEXT_PUBLIC_FORMSPREE_ID=https://formspree.io/f/mreoyono
#   NEXT_PUBLIC_FORMSPREE_ID=mreoyono
NEXT_PUBLIC_FORMSPREE_ID=https://formspree.io/f/mreoyono
